# Low-memory (8 GB) setup for Old Bailey Legal Fiction Generator
# Copy to .env and adjust as needed

OLLAMA_MODEL=smollm2:360m
OLLAMA_NUM_CTX=2048
OLLAMA_GENERATE_TIMEOUT=600
PROMPT_FULL_TEXT_TRUNCATE=5000

# Optional: Vercel deploy hook — pinged after each story generation to rebuild your V0 site
# Create one in Vercel: Project → Settings → Git → Deploy Hooks
# VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...
